# Chatwoot 인스턴스 접속 정보
CHATWOOT_API_URL=https://your-chatwoot-instance.com
# User(관리자/상담원) 토큰 — Profile Settings > Access Token. 배정/라벨/우선순위 등 관리 API용
CHATWOOT_API_TOKEN=your_chatwoot_api_token
# AgentBot access_token — Settings > Bots에서 발급. 봇 응답을 봇 명의로 보낼 때 사용
# 비우면 CHATWOOT_API_TOKEN으로 폴백(봇 응답이 상담원 명의로 기록됨)
CHATWOOT_BOT_TOKEN=

# 웹훅 서명 시크릿 (Chatwoot 설정 > 웹훅 > Secret Token)
# 비워두면 서명 검증 생략 (로컬 개발용)
CHATWOOT_WEBHOOK_SECRET=

# Groq API 키 (https://console.groq.com/keys)
GROQ_API_KEY=